# Optional NLP backend models.
# Copy this file to .env, then install the matching packages before enabling them.

# HanLP default alias is resolved in src/nlp_backend.py to:
# hanlp.pretrained.mtl.CLOSE_TOK_POS_NER_SRL_DEP_SDP_CON_ELECTRA_SMALL_ZH
HANLP_MODEL=default

# Modern LTP can load HuggingFace-style model names.
LTP_MODEL=LTP/small

# Legacy pyltp model paths. Leave these empty unless you have local .model files.
# PYLTP_CWS_MODEL=models/ltp_data_v3.4.0/cws.model
# PYLTP_POS_MODEL=models/ltp_data_v3.4.0/pos.model
# PYLTP_NER_MODEL=models/ltp_data_v3.4.0/ner.model
